{{/* WSL-only quiet-login markers: deploy on wsl, ignore elsewhere. */}}
{{ if ne .machine "wsl" }}
.hushlogin
.motd_shown
.sudo_as_admin_successful
{{ end -}}

{{/* yazi and gomi are extra-tier (laptop/wsl); don't deploy their configs on servers. */}}
{{ if eq .machine "server" }}
.config/yazi
.config/gomi
{{ end -}}

{{/* neutronics drop-in for workstations (laptop/wsl); the rest of ~/.zsh stays unmanaged. */}}
{{ if eq .machine "server" }}
.zsh/neutronics.zsh
{{ end -}}
